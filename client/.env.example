# Copy to client/.env when running locally or pointing at a deployed backend
# Example: VITE_API_URL=http://localhost:5001
VITE_API_URL=http://localhost:5001

# Notes:
# - Vite will only pick up environment vars at build/dev start. Restart the dev server after creating/editing this file.
# - Do NOT commit a client/.env with private production URLs unless intended.
